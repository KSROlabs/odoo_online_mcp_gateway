# Copy to ".env" and fill values (do not commit secrets).

# Odoo Online connection
ODOO_BASE_URL=https://yourcompany.odoo.com
ODOO_DB=your_db_name
ODOO_LOGIN=integration@yourcompany.com
ODOO_PASSWORD=YOUR_PASSWORD_OR_API_KEY

# Gateway token (set both to the same value)
GATEWAY_TOKEN_1=PASTE_A_LONG_RANDOM_TOKEN
GATEWAY_TOKEN=PASTE_A_LONG_RANDOM_TOKEN

# Optional debugging
# GATEWAY_DEBUG=1
